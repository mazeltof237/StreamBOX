# =========================================================
#  StreamBOX Frontend — Variables d'environnement
# =========================================================
# NOTE : Angular CLI n'injecte pas automatiquement les .env.
# Cette variable est documentaire ; la vraie URL backend doit
# être renseignée dans `src/environments/environment.prod.ts`
# AVANT le `npm run build` (ou via la commande build Vercel).
#
# En local : utiliser le proxy (proxy.conf.json) → laisser vide.
# En prod  : https://streambox-api.onrender.com
# =========================================================

API_BASE_URL=https://streambox-api.onrender.com
