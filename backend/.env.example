# =========================================================
#  StreamBOX Backend — Variables d'environnement
#  Copier ce fichier en `.env` (en local) ou les définir
#  dans le dashboard Render (en production).
# =========================================================

# --- Django ---
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-please-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données ---
# Laisser vide en local → SQLite.
# En prod (Render) : URL PostgreSQL fournie par Render.
DATABASE_URL=

# --- CORS ---
# URLs autorisées à appeler l'API (frontend Angular).
# En prod : https://ton-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- JWT (optionnel, valeurs par défaut OK) ---
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
